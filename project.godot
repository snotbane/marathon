; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="marathon_task_runner"
run/main_scene="uid://c2sk65yfam5b0"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://bogkcdp677xc7"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

naming/node_name_num_separator=2
naming/node_name_casing=2
naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/marathon_task_runner/fatlas/plugin.cfg", "res://addons/marathon_task_runner/task_runner/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/marathon_task_runner/fatlas/icons/": "yellow",
"res://addons/marathon_task_runner/fatlas/sunkist/materials/": "pink",
"res://addons/marathon_task_runner/fatlas/sunkist/shaders/": "purple",
"res://addons/marathon_task_runner/task_runner/icons/": "yellow"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method.mobile="gl_compatibility"

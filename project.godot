; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sunkist Tools"
run/main_scene="uid://c2sk65yfam5b0"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://bogkcdp677xc7"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

naming/node_name_num_separator=2
naming/node_name_casing=2
naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/sunkist/base/plugin.cfg", "res://addons/sunkist/task_runner/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/sunkist/_readme/": "gray",
"res://addons/sunkist/materials/": "pink",
"res://addons/sunkist/scenes/": "green",
"res://addons/sunkist/scripts/": "blue",
"res://addons/sunkist/shaders/": "purple",
"res://addons/sunkist/task_runner/tasks/": "teal",
"res://addons/sunkist/ui/": "red"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[sub_resource type="GDScript" id="GDScript_5g44h"]
script/source = "@tool
extends Node3D

@export var spin_speed: float = 1.0
@export var oscillation_amplitude: float = 1.0
@export var oscillation_speed: float = 1.0


@onready var in_edited_scene: bool = get_tree().edited_scene_root == owner


func _process(delta: float) -> void:
	if in_edited_scene: return
	
	rotation_degrees.x = cos(Time.get_ticks_msec() * 0.001 * oscillation_speed) * oscillation_amplitude
	rotation_degrees.y = wrapf(rotation_degrees.y + delta * spin_speed, 0.0, 360.0)
"

